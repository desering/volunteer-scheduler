#!/bin/bash

set -e
echo "Running pre-commit checks..."

DOCKER_CONTAINER_NAME="husky-bun-runtime"

if ! command -v bun >/dev/null 2>&1; then
    echo "no local 'bun', using docker" >&2
    if ! command -v docker >/dev/null 2>&1; then
      echo "oh, no even 'docker'" >&2
      exit 1
    else
      docker rm -f "$DOCKER_CONTAINER_NAME" 2>/dev/null || true
      BUN_RUNTIME_CMD="docker compose -f docker-compose.yml run --rm --no-deps --workdir /app --name $DOCKER_CONTAINER_NAME bun-dev"
    fi
else
  BUN_RUNTIME_CMD="bun"
fi

if ! $BUN_RUNTIME_CMD check:staged; then
    echo ""
    echo "X ERROR: Biome check failed!"
    echo ""
    echo "To fix the issues, run:"
    echo "  bun lint:staged"
    echo ""
    echo "Then stage your changes and commit again:"
    echo "  git add ."
    echo "  git commit"
    echo ""
    exit 1
fi

echo "✓ All pre-commit checks passed."
