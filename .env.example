# postgres service (docker compose)
POSTGRES_DB=schedule
POSTGRES_USER=schedule
POSTGRES_PASSWORD=schedule


# bun app
SERVER_URL=http://localhost:3000
DATABASE_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
PAYLOAD_SECRET=PAYLOAD_SECRET_PLACEHOLDER

# OIDC
OIDC_SESSION_SECRET=OIDC_SESSION_SECRET_PLACEHOLDER
AUTHENTIK_ISSUER=https://auth.desering.org/application/o/volunteer-scheduler/
AUTHENTIK_CLIENT_ID=AUTHENTIK_CLIENT_ID_PLACEHOLDER
AUTHENTIK_CLIENT_SECRET=AUTHENTIK_CLIENT_SECRET_PLACEHOLDER

## branding
ORG_NAME="De Sering"

## e-mail settings
EMAIL_FROM_ADDRESS=schedule@localhost
EMAIL_FROM_NAME='De Sering Schedule'
SMTP_HOST=maildev
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
